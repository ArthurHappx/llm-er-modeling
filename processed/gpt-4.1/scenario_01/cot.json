{
  "tables": {
    "Hospital": {
      "*hospital_id": "int()",
      "name": "varchar(200)",
      "code": "varchar(20)",
      "state": "varchar(2)",
      "city": "varchar(100)",
      "address_text": "varchar(255)",
      "active_flag": "boolean()"
    },
    "DepartmentType": {
      "*department_type_id": "int()",
      "name": "varchar(100)",
      "description": "varchar(255)"
    },
    "HospitalDepartment": {
      "*hospital_department_id": "int()",
      "+hospital_id": "int()",
      "+department_type_id": "int()",
      "operational_capacity": "int()",
      "is_active": "boolean()"
    },
    "Person": {
      "*person_id": "int()",
      "full_name": "varchar(200)",
      "cpf": "varchar(14)",
      "rg": "varchar(20)",
      "date_of_birth": "date()",
      "primary_phone": "varchar(20)",
      "secondary_phone": "varchar(20)",
      "email": "varchar(150)",
      "registration_date": "datetime()",
      "is_active": "boolean()"
    },
    "PersonRole": {
      "*person_role_id": "int()",
      "+person_id": "int()",
      "role_type": "varchar(30)",
      "role_start_date": "date()",
      "role_end_date": "date()"
    },
    "Employee": {
      "*employee_id": "int()",
      "+person_id": "int()",
      "employee_number": "varchar(30)",
      "hire_date": "date()",
      "termination_date": "date()",
      "is_healthcare_professional": "boolean()"
    },
    "Physician": {
      "*physician_id": "int()",
      "+employee_id": "int()",
      "crm_number": "varchar(30)",
      "specialty": "varchar(100)"
    },
    "Nurse": {
      "*nurse_id": "int()",
      "+employee_id": "int()",
      "coren_number": "varchar(30)",
      "level": "varchar(50)"
    },
    "Resident": {
      "*resident_id": "int()",
      "+physician_id": "int()",
      "residency_program": "varchar(150)",
      "start_date": "date()",
      "end_date": "date()"
    },
    "ResidentSupervision": {
      "*resident_supervision_id": "int()",
      "+resident_id": "int()",
      "+supervising_physician_id": "int()",
      "supervision_start_date": "date()",
      "supervision_end_date": "date()"
    },
    "Patient": {
      "*patient_id": "int()",
      "+person_id": "int()",
      "medical_record_number": "varchar(30)",
      "current_status": "varchar(30)",
      "wristband_id": "varchar(50)"
    },
    "Visitor": {
      "*visitor_id": "int()",
      "+person_id": "int()",
      "visitor_type": "varchar(50)",
      "notes": "varchar(255)"
    },
    "EmployeeDependent": {
      "*employee_dependent_id": "int()",
      "+employee_id": "int()",
      "+patient_id": "int()",
      "relationship_type": "varchar(50)",
      "start_date": "date()",
      "end_date": "date()"
    },
    "Address": {
      "*address_id": "int()",
      "+person_id": "int()",
      "street": "varchar(150)",
      "number": "varchar(20)",
      "complement": "varchar(100)",
      "neighborhood": "varchar(100)",
      "city": "varchar(100)",
      "state": "varchar(2)",
      "postal_code": "varchar(15)",
      "country": "varchar(50)",
      "is_primary": "boolean()",
      "last_update_ts": "datetime()"
    },
    "IdentificationCard": {
      "*card_id": "int()",
      "card_number": "varchar(50)",
      "card_type": "varchar(30)",
      "access_level": "varchar(30)",
      "issue_date": "date()",
      "expiry_date": "date()",
      "is_active": "boolean()",
      "has_photo": "boolean()"
    },
    "CardAssignment": {
      "*card_assignment_id": "int()",
      "+card_id": "int()",
      "+person_id": "int()",
      "assignment_start_ts": "datetime()",
      "assignment_end_ts": "datetime()",
      "is_personalized": "boolean()"
    },
    "PatientVisit": {
      "*patient_visit_id": "int()",
      "+patient_id": "int()",
      "+hospital_id": "int()",
      "admission_ts": "datetime()",
      "discharge_ts": "datetime()",
      "admission_type": "varchar(30)",
      "initial_hospital_department_id": "int()",
      "final_discharge_reason": "varchar(100)"
    },
    "PatientMovement": {
      "*patient_movement_id": "int()",
      "+patient_visit_id": "int()",
      "+from_hospital_department_id": "int()",
      "+to_hospital_department_id": "int()",
      "movement_ts": "datetime()",
      "movement_type": "varchar(30)",
      "notes": "varchar(255)"
    },
    "VisitorAccess": {
      "*visitor_access_id": "int()",
      "+visitor_id": "int()",
      "+hospital_id": "int()",
      "+hospital_department_id": "int()",
      "+card_id": "int()",
      "+patient_id": "int()",
      "entry_ts": "datetime()",
      "exit_ts": "datetime()",
      "access_purpose": "varchar(100)",
      "special_authorization_flag": "boolean()",
      "special_authorization_by": "varchar(150)",
      "notes": "varchar(255)"
    },
    "DepartmentShift": {
      "*department_shift_id": "int()",
      "+hospital_department_id": "int()",
      "shift_name": "varchar(50)",
      "start_time": "time()",
      "end_time": "time()",
      "is_rotating": "boolean()"
    },
    "DepartmentShiftLeader": {
      "*department_shift_leader_id": "int()",
      "+department_shift_id": "int()",
      "+employee_id": "int()",
      "leader_start_ts": "datetime()",
      "leader_end_ts": "datetime()"
    },
    "EmploymentContract": {
      "*employment_contract_id": "int()",
      "+employee_id": "int()",
      "+hospital_id": "int()",
      "contract_type": "varchar(20)",
      "start_date": "date()",
      "end_date": "date()",
      "weekly_hours": "decimal(5,2)",
      "notes": "varchar(255)"
    },
    "WorkSchedule": {
      "*work_schedule_id": "int()",
      "+employment_contract_id": "int()",
      "+hospital_department_id": "int()",
      "day_of_week": "int()",
      "scheduled_start_ts": "datetime()",
      "scheduled_end_ts": "datetime()",
      "schedule_type": "varchar(30)"
    },
    "TimeClockRecord": {
      "*time_clock_record_id": "int()",
      "+employee_id": "int()",
      "+card_id": "int()",
      "clock_in_ts": "datetime()",
      "clock_out_ts": "datetime()",
      "source": "varchar(30)",
      "matched_schedule_id": "int()",
      "anomaly_flag": "boolean()",
      "anomaly_type": "varchar(50)"
    },
    "AvailabilityException": {
      "*availability_exception_id": "int()",
      "+employment_contract_id": "int()",
      "exception_type": "varchar(30)",
      "start_date": "date()",
      "end_date": "date()",
      "note": "varchar(255)"
    }
  },
  "relations": [
    "Hospital:hospital_id 1--* HospitalDepartment:hospital_id",
    "DepartmentType:department_type_id 1--* HospitalDepartment:department_type_id",
    "Person:person_id 1--* PersonRole:person_id",
    "Person:person_id 1--* Employee:person_id",
    "Employee:employee_id 1--* Physician:employee_id",
    "Employee:employee_id 1--* Nurse:employee_id",
    "Physician:physician_id 1--* Resident:physician_id",
    "Resident:resident_id 1--* ResidentSupervision:resident_id",
    "Physician:physician_id 1--* ResidentSupervision:supervising_physician_id",
    "Person:person_id 1--* Patient:person_id",
    "Person:person_id 1--* Visitor:person_id",
    "Employee:employee_id 1--* EmployeeDependent:employee_id",
    "Patient:patient_id 1--* EmployeeDependent:patient_id",
    "Person:person_id 1--* Address:person_id",
    "Person:person_id 1--* CardAssignment:person_id",
    "IdentificationCard:card_id 1--* CardAssignment:card_id",
    "Patient:patient_id 1--* PatientVisit:patient_id",
    "Hospital:hospital_id 1--* PatientVisit:hospital_id",
    "HospitalDepartment:hospital_department_id 1--* PatientVisit:initial_hospital_department_id",
    "PatientVisit:patient_visit_id 1--* PatientMovement:patient_visit_id",
    "HospitalDepartment:hospital_department_id 1--* PatientMovement:from_hospital_department_id",
    "HospitalDepartment:hospital_department_id 1--* PatientMovement:to_hospital_department_id",
    "Visitor:visitor_id 1--* VisitorAccess:visitor_id",
    "Hospital:hospital_id 1--* VisitorAccess:hospital_id",
    "HospitalDepartment:hospital_department_id 1--* VisitorAccess:hospital_department_id",
    "IdentificationCard:card_id 1--* VisitorAccess:card_id",
    "Patient:patient_id 1--* VisitorAccess:patient_id",
    "HospitalDepartment:hospital_department_id 1--* DepartmentShift:hospital_department_id",
    "DepartmentShift:department_shift_id 1--* DepartmentShiftLeader:department_shift_id",
    "Employee:employee_id 1--* DepartmentShiftLeader:employee_id",
    "Employee:employee_id 1--* EmploymentContract:employee_id",
    "Hospital:hospital_id 1--* EmploymentContract:hospital_id",
    "EmploymentContract:employment_contract_id 1--* WorkSchedule:employment_contract_id",
    "HospitalDepartment:hospital_department_id 1--* WorkSchedule:hospital_department_id",
    "Employee:employee_id 1--* TimeClockRecord:employee_id",
    "IdentificationCard:card_id 1--* TimeClockRecord:card_id",
    "WorkSchedule:work_schedule_id 1--* TimeClockRecord:matched_schedule_id",
    "EmploymentContract:employment_contract_id 1--* AvailabilityException:employment_contract_id"
  ],
  "rankAdjustments": "",
  "label": "Integrated Hospital Network Management ER Model"
}