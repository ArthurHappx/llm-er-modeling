{
  "tables": {
    "Hospital": {
      "*hospital_id": "int",
      "name": "varchar(100)",
      "location": "varchar(200)",
      "state": "varchar(50)"
    },
    "Department": {
      "*department_id": "int",
      "name": "varchar(50)",
      "capacity": "int",
      "hospital_id": "int"
    },
    "DepartmentCoordinator": {
      "*coordinator_id": "int",
      "start_date": "date",
      "end_date": "date",
      "department_id": "int",
      "personnel_id": "int"
    },
    "Personnel": {
      "*personnel_id": "int",
      "full_name": "varchar(150)",
      "cpf": "varchar(14)",
      "rg": "varchar(20)",
      "date_of_birth": "date",
      "role": "varchar(50)"
    },
    "Patient": {
      "*patient_id": "int",
      "wristband_id": "varchar(20)",
      "personnel_id": "int"
    },
    "Visitor": {
      "*visitor_id": "int",
      "card_id": "varchar(20)",
      "visit_type": "varchar(50)",
      "personnel_id": "int"
    },
    "Employee": {
      "*employee_id": "int",
      "contract_type": "varchar(50)",
      "professional_credential": "varchar(50)",
      "personnel_id": "int"
    },
    "Address": {
      "*address_id": "int",
      "street": "varchar(200)",
      "city": "varchar(100)",
      "state": "varchar(50)",
      "personnel_id": "int",
      "last_updated": "timestamp"
    },
    "IdentificationCard": {
      "*card_id": "varchar(20)",
      "issue_date": "date",
      "expiry_date": "date",
      "card_type": "varchar(50)",
      "is_active": "boolean",
      "photo": "blob"
    },
    "WorkSchedule": {
      "*schedule_id": "int",
      "employee_id": "int",
      "start_date": "date",
      "end_date": "date",
      "shift_type": "varchar(50)"
    },
    "TimeClockRecord": {
      "*record_id": "int",
      "employee_id": "int",
      "clock_in": "datetime",
      "clock_out": "datetime",
      "hospital_id": "int"
    },
    "AvailabilityException": {
      "*exception_id": "int",
      "employee_id": "int",
      "start_date": "date",
      "end_date": "date",
      "exception_type": "varchar(50)",
      "notes": "text"
    },
    "PatientMovement": {
      "*movement_id": "int",
      "patient_id": "int",
      "department_id": "int",
      "movement_date": "datetime",
      "movement_type": "varchar(50)"
    },
    "DepartmentCapacityAlert": {
      "*alert_id": "int",
      "department_id": "int",
      "alert_percentage": "decimal(5,2)",
      "alert_date": "datetime"
    }
  },
  "relations": [
    "Hospital:hospital_id 1--* Department:hospital_id",
    "Department:department_id 1--* DepartmentCoordinator:department_id",
    "Personnel:personnel_id 1--* Patient:personnel_id",
    "Personnel:personnel_id 1--* Visitor:personnel_id",
    "Personnel:personnel_id 1--* Employee:personnel_id",
    "Employee:employee_id 1--+ WorkSchedule:employee_id",
    "Employee:employee_id 1--+ TimeClockRecord:employee_id",
    "Employee:employee_id 1--+ AvailabilityException:employee_id",
    "Personnel:personnel_id 1--* Address:personnel_id",
    "Employee:employee_id 1--* IdentificationCard:employee_id",
    "IdentificationCard:card_id ?--1 Patient:card_id",
    "IdentificationCard:card_id ?--1 Visitor:card_id",
    "Department:department_id 1--+ DepartmentCapacityAlert:department_id",
    "Patient:patient_id 1--+ PatientMovement:patient_id",
    "Hospital:hospital_id 1--+ TimeClockRecord:hospital_id"
  ],
  "rankAdjustments": "",
  "label": "Integrated Hospital Management System for Multiple Facilities"
}