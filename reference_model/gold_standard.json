{
  "description": "Canonical, cumulative gold-standard feature inventory derived from the three requirement scenarios and the existing scenario_3 reference model. Scenario 2 extends scenario 1; scenario 3 extends scenario 2.",
  "scenario_01": {
    "entities": {
      "hospital": ["id", "name", "cnpj", "state", "city"],
      "department": ["id", "hospital_id", "name", "type", "capacity"],
      "person": ["id", "full_name", "cpf", "rg", "birth_date", "phone"],
      "address": ["id", "person_id", "street", "number", "city", "state", "postal_code", "last_updated"],
      "employee": ["id", "person_id"],
      "physician": ["id", "employee_id", "crm"],
      "nurse": ["id", "employee_id", "coren"],
      "resident": ["id", "physician_id", "supervisor_physician_id"],
      "researcher": ["id", "employee_id"],
      "administrative_staff": ["id", "employee_id", "position"],
      "patient": ["id", "person_id", "wristband", "status"],
      "visitor": ["id", "person_id", "type"],
      "dependent": ["id", "employee_id", "patient_id", "relationship"],
      "companion": ["id", "visitor_id", "patient_id", "start", "end"],
      "identification_card": ["id", "number", "issue_date", "expiry_date", "type", "active", "photo"],
      "card_assignment": ["id", "card_id", "person_id", "start", "end"],
      "access_event": ["id", "person_id", "card_id", "department_id", "timestamp", "direction", "authorized"],
      "employment_contract": ["id", "employee_id", "hospital_id", "type", "start_date", "end_date"],
      "department_shift": ["id", "department_id", "start_time", "end_time"],
      "department_responsibility": ["id", "department_id", "shift_id", "employee_id", "start", "end"],
      "work_schedule": ["id", "contract_id", "department_id", "start", "end"],
      "time_record": ["id", "employee_id", "card_id", "clock_in", "clock_out"],
      "availability_exception": ["id", "employee_id", "start_date", "end_date", "type", "note"],
      "patient_visit": ["id", "patient_id", "hospital_id", "admission", "discharge", "status"],
      "patient_movement": ["id", "patient_id", "department_id", "timestamp", "type"],
      "department_occupancy": ["id", "department_id", "timestamp", "occupancy", "capacity", "threshold"]
    },
    "relations": [
      ["hospital", "department", "1:N"], ["person", "address", "1:N"],
      ["person", "employee", "1:N"], ["person", "patient", "1:N"],
      ["person", "visitor", "1:N"], ["employee", "physician", "1:1"],
      ["employee", "nurse", "1:1"], ["physician", "resident", "1:N"],
      ["physician", "resident", "1:N"], ["employee", "dependent", "1:N"],
      ["patient", "dependent", "1:N"], ["visitor", "companion", "1:N"],
      ["patient", "companion", "1:N"], ["person", "card_assignment", "1:N"],
      ["identification_card", "card_assignment", "1:N"], ["person", "access_event", "1:N"],
      ["identification_card", "access_event", "1:N"], ["department", "access_event", "1:N"],
      ["employee", "employment_contract", "1:N"], ["hospital", "employment_contract", "1:N"],
      ["department", "department_shift", "1:N"], ["department_shift", "department_responsibility", "1:N"],
      ["employee", "department_responsibility", "1:N"], ["employment_contract", "work_schedule", "1:N"],
      ["employee", "time_record", "1:N"], ["identification_card", "time_record", "1:N"],
      ["employee", "availability_exception", "1:N"], ["patient", "patient_visit", "1:N"],
      ["patient_visit", "patient_movement", "1:N"], ["department", "patient_movement", "1:N"],
      ["department", "department_occupancy", "1:N"]
    ]
  },
  "scenario_02_additions": {
    "entities": {
      "companion_authorization": ["id", "companion_id", "authorized_by", "start", "end", "reason"],
      "card_status_history": ["id", "card_id", "status", "timestamp", "reason"],
      "card_loss_event": ["id", "card_id", "person_id", "timestamp", "replacement_card_id"],
      "card_failure_event": ["id", "card_id", "person_id", "timestamp", "reason", "read_attempt"],
      "manual_access_validation": ["id", "failure_event_id", "responsible_employee_id", "document", "timestamp"],
      "security_alert": ["id", "card_id", "timestamp", "type"]
    },
    "entity_attribute_additions": {"patient": ["vip"]},
    "relations": [
      ["companion", "companion_authorization", "1:N"],
      ["identification_card", "card_status_history", "1:N"],
      ["identification_card", "card_loss_event", "1:N"],
      ["person", "card_loss_event", "1:N"],
      ["identification_card", "card_failure_event", "1:N"],
      ["person", "card_failure_event", "1:N"],
      ["card_failure_event", "manual_access_validation", "1:N"],
      ["employee", "manual_access_validation", "1:N"],
      ["identification_card", "security_alert", "1:N"]
    ]
  },
  "scenario_03_additions": {
    "entities": {
      "shift_swap": ["id", "schedule_id", "origin_employee_id", "destination_employee_id", "coordinator_id", "request_date", "approval_date", "justification"],
      "patient_isolation": ["id", "patient_id", "physician_id", "start", "end", "reason"]
    },
    "relations": [
      ["work_schedule", "shift_swap", "1:N"],
      ["employee", "shift_swap", "1:N"],
      ["patient", "patient_isolation", "1:N"],
      ["physician", "patient_isolation", "1:N"]
    ]
  }
}
